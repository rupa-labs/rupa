[package]
name = "{{name}}"
version = "0.1.0"
edition = "2021"
authors = ["Artisan"]
description = "A new Rupa masterpiece."

[dependencies]
rupa = { git = "https://github.com/rupa-labs/rupa", features = {{features}} }
serde = { version = "1.0", features = ["derive"] }
log = "0.4"
env_logger = "0.10"
