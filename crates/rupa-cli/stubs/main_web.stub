use rupa::prelude::*;
use wasm_bindgen::prelude::*;

#[wasm_bindgen(start)]
pub fn start() {
    App::new("{{title}} Web")
        .root(
            VStack::new()
                .p(Step::S4)
                .items_center()
                .child(Text::new("🌐 WEB EXCELLENCE").font_bold())
                .child(Text::new("Built with Rust & WASM"))
        )
        .run();
}
